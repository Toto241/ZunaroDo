# Beispiel-Umgebung fuer tools/payment_server.py (Merchant of Record Webhook).
# Kopieren nach payment-server.env und NUR auf dem Anbieter-Server ablegen.
# Niemals den Private-Key ins Git-Repository committen.
#
# Keypair erzeugen:
#   python tools/gen_license.py keygen
# Public-Key in services/license_token.py (DEFAULT_PUBLIC_KEY_HEX) eintragen.
# Private-Key hier als PRIV_HEX setzen.

PRIV_HEX=
PADDLE_SECRET=
LEMON_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alltagshelfer@zunarodo.github.io

# Paddle Price-ID -> tier:persons (Beispiel)
# PADDLE_MAPPING=pri_MONTHLY=pro_monthly:2,pri_ANNUAL=pro_annual:2,pri_FAMILY=pro_family:5
