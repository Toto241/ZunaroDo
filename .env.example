# ZunaroDo – Beispiel-Umgebungsvariablen
#
# Diese Datei dokumentiert alle unterstuetzten Umgebungsvariablen mit LEEREN
# Werten. Kopiere sie bei Bedarf nach `.env` und trage echte Werte dort ein –
# `.env` ist via .gitignore ausgeschlossen und darf NIE eingecheckt werden.
#
# Grundsatz: ZunaroDo laeuft vollstaendig offline. Ohne gesetzte Variablen
# verlassen keine Daten das Geraet. Alle Cloud-/Netz-Funktionen sind optional
# und werden erst durch das Setzen der jeweiligen Variablen aktiv.
#
# Secrets (mit [SECRET] markiert) werden NICHT in der Datenbank gespeichert –
# sie kommen ausschliesslich aus Umgebungsvariablen oder dem OS-Schluesselspeicher.

# --- KI-Assistent (Google Gemini) – optional --------------------------------
# Ist GOOGLE_API_KEY leer, laeuft der Assistent regelbasiert/offline.
# GEMINI_API_KEY wird alternativ als Fallback akzeptiert.
GOOGLE_API_KEY=                      # [SECRET] Google-AI-Studio/Gemini API-Key
ALLTAGSHELFER_GEMINI_MODEL=          # Default: gemini-2.5-flash
ALLTAGSHELFER_FORCE_GEMINI_REST=     # 1 = REST-Pfad erzwingen (v. a. Tests/Desktop)

# --- Lokale Datenbank-Verschluesselung (SQLCipher) – optional ---------------
ALLTAGSHELFER_DB_KEY=                # [SECRET] SQLCipher-Schluessel der Live-DB
ALLTAGSHELFER_BACKUP_KEY=            # [SECRET] separater Schluessel fuer Backups

# --- Posteingang / Mail-Import (IMAP) – optional ----------------------------
ALLTAGSHELFER_IMAP_HOST=             # z. B. imap.example.com
ALLTAGSHELFER_IMAP_USER=
ALLTAGSHELFER_IMAP_PASS=             # [SECRET] IMAP-Passwort
ALLTAGSHELFER_IMAP_FOLDER=           # Default: INBOX

# --- Mehrgeraete-Synchronisation – optional ---------------------------------
# Entweder Datei-Sync (geteilter Ordner) ODER HTTP(S)-Sync-Server verwenden.
ALLTAGSHELFER_SYNC_DIR=              # Pfad zu geteiltem Ordner (Dropbox/OneDrive/…)
ALLTAGSHELFER_SYNC_URL=              # http(s)://host:5151 fuer HTTP-Sync
ALLTAGSHELFER_SYNC_TOKEN=            # [SECRET] Auth-Token fuer den Sync-Server
ALLTAGSHELFER_DEVICE_ID=             # stabile Geraete-ID (sonst automatisch)
ALLTAGSHELFER_SYNC_LOG=              # Sync-Server: Pfad fuer das Event-Log (JSONL)

# --- Profile & Verzeichnisse ------------------------------------------------
ALLTAGSHELFER_PROFILE=               # benanntes Profil (eigene DB + State-Dir)
ALLTAGSHELFER_DATA_DIR=              # Daten-Verzeichnis ueberschreiben (hat Vorrang)
ALLTAGSHELFER_CONFIG_DIR=            # Konfig-Verzeichnis ueberschreiben (Tests/portabel)

# --- Betrieb / Diagnose -----------------------------------------------------
ALLTAGSHELFER_LOG_LEVEL=             # Default: INFO (DEBUG/WARNING/…)
ALLTAGSHELFER_PAIRING_BACKEND=       # keyring (Default) | memory (nur Tests/CI)
ALLTAGSHELFER_PLATFORM=              # Plattform-Override fuer Mobile-Markup

# --- Bezahl-/Lizenzserver (nur Self-Hosting des Verify-Servers) -------------
ZUNARODO_PLAY_VERIFY_URL=            # URL des Play-Kauf-Verifikationsservers

# Hinweis: SMTP (Mailversand) wird in der App unter Einstellungen konfiguriert
# und in der lokalen DB gehalten – es gibt dafuer bewusst keine Umgebungsvariablen.
